/
  Cache-Control: public, max-age=300

/index.html
  Cache-Control: public, max-age=300

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/images/backgrounds/*
  Cache-Control: public, max-age=86400

/images/avatar/*
  Cache-Control: public, max-age=86400

/config/site.config.json
  Cache-Control: no-store
